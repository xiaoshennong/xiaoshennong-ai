# LLM Provider: mock / yunwu / kimi / deepseek / openai
LLM_PROVIDER=mock

# Yunwu AI (推荐，OpenAI兼容)
YUNWU_API_KEY=your-yunwu-api-key
YUNWU_API_BASE=https://yunwu.ai/v1

# Kimi (Moonshot AI)
KIMI_API_KEY=your-kimi-api-key
KIMI_API_BASE=https://api.moonshot.cn/v1

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# Service Config
PORT=5001
FLASK_DEBUG=false

# 小神农中医AI - 环境变量示例
# 所有 LLM 调用统一使用 Yunwu AI（OpenAI 兼容格式）

# LLM Provider: 固定为 yunwu（代码已强制使用 yunwu.ai，其他值会被忽略）
LLM_PROVIDER=yunwu

# Yunwu AI（必填）
YUNWU_API_KEY=your-yunwu-api-key
YUNWU_API_BASE=https://yunwu.ai/v1
# 可选：默认模型，如 gpt-4o-mini、deepseek-chat 等（以 Yunwu 后台可用模型为准）
# YUNWU_MODEL=gpt-4o-mini

# Admin Token（后台管理系统登录用，生产环境请务必修改）
ADMIN_TOKEN=xiaoshennong-admin

# Service Config
PORT=5001
FLASK_DEBUG=false

# 短信服务（可选，不配置时为开发模式：验证码打印到后端日志并在响应中返回 dev_code）
# 生产环境配置阿里云短信（签名/模板需企业资质报备），配置后 dev_code 自动关闭
# SMS_PROVIDER=aliyun
# SMS_ALIYUN_ACCESS_KEY=your-access-key
# SMS_ALIYUN_SECRET=your-secret
# SMS_ALIYUN_SIGN=小神农
# SMS_ALIYUN_TEMPLATE=SMS_XXXXXX

# 联网搜索模块兼容旧配置名，优先读取 YUNWU_API_KEY
# 如需单独指定搜索模型可保留：
# WEBSEARCH_MODEL=gpt-4o-mini

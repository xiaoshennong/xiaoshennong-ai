# 小神农中医AI - 环境变量模板
# 复制为 .env 后填入实际值

# ============================================
# LLM API配置（至少填一个）
# ============================================

# LLM提供商：mock / yunwu / kimi / deepseek / openai
LLM_PROVIDER=mock

# Yunwu AI（推荐，国内速度快）
YUNWU_API_KEY=your-yunwu-api-key-here
YUNWU_API_BASE=https://yunwu.ai/v1

# Kimi（Moonshot AI）
KIMI_API_KEY=your-kimi-api-key-here
KIMI_API_BASE=https://api.moonshot.cn/v1

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# ============================================
# 服务配置
# ============================================

# 服务端口（容器内部，一般不改）
PORT=5001

# 域名（用于Nginx配置和SSL证书）
DOMAIN=your-domain.com

# ============================================
# 可选高级配置
# ============================================

# 调试模式（生产环境设为false）
FLASK_DEBUG=false

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

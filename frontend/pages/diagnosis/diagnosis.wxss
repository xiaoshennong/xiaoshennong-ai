page {
  background: #f7f3e9;
  font-family: 'Noto Serif SC', 'Source Han Serif SC', 'SimSun', 'STSong', serif;
}


page::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(180, 160, 130, 0.05) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(160, 140, 110, 0.04) 0%, transparent 50%);
  pointer-events: none;
  z-index: -1;
}

/* 小神农中医AI - 辨证页面样式 */
.container {
  padding: 30rpx;
  background: #f7f3e9;
  min-height: 100vh;
}

/* 进度条 */
.progress-bar {
  margin-bottom: 30rpx;
  position: relative;
  height: 8rpx;
  background: #d4c4b0;
  border-radius: 2rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #a53232, #8a2525);
  border-radius: 2rpx;
  transition: width 0.3s ease;
}

.progress-text {
  position: absolute;
  right: 0;
  top: -40rpx;
  font-size: 24rpx;
  color: #8b7355;
}

/* 欢迎页 */
.welcome-screen {
  text-align: center;
  padding: 60rpx 40rpx;
}

.welcome-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.welcome-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #8a2525;
  margin-bottom: 20rpx;
}

.welcome-desc {
  display: block;
  font-size: 28rpx;
  color: #5d4037;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.feature-list {
  text-align: left;
  margin: 40rpx 0;
}

.feature-item {
  display: flex;
  align-items: center;
  margin: 20rpx 0;
  font-size: 28rpx;
  color: #5d4037;
}

.feature-check {
  color: #a53232;
  font-weight: bold;
  margin-right: 20rpx;
  font-size: 32rpx;
}

.start-btn {
  margin-top: 60rpx;
  background: linear-gradient(135deg, #a53232 0%, #8a2525 100%);
  color: white;
  border-radius: 8rpx;
  font-size: 32rpx;
  padding: 30rpx 80rpx;
  border: none;
}

/* 问题页 */
.question-screen {
  padding: 20rpx 0;
}

.question-card {
  background: #fffdf8;
  border-radius: 4rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 2rpx 10rpx rgba(43, 27, 18, 0.12);
}

.question-number {
  display: block;
  font-size: 24rpx;
  color: #a53232;
  margin-bottom: 15rpx;
}

.question-text {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #8a2525;
  margin-bottom: 30rpx;
  line-height: 1.5;
}

/* 选项 */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  padding: 30rpx;
  border-radius: 4rpx;
  border: 2rpx solid #d4c4b0;
  background: #f7f3e9;
  transition: all 0.2s;
}

.option-item.selected {
  border-color: #a53232;
  background: #f0e8d8;
}

.option-item:active {
  transform: scale(0.98);
}

.option-text {
  font-size: 30rpx;
  color: #2b2b2b;
}

/* 文本输入 */
.text-input-wrap {
  margin-top: 20rpx;
}

.text-input {
  width: 100%;
  height: 200rpx;
  padding: 20rpx;
  border: 2rpx solid #d4c4b0;
  border-radius: 4rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

/* 导航按钮 */
.nav-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.nav-btn {
  flex: 1;
  padding: 30rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  border: none;
}

.nav-btn.prev {
  background: #efe8d8;
  color: #5a5a5a;
}

.nav-btn.next {
  background: linear-gradient(135deg, #a53232 0%, #8a2525 100%);
  color: white;
}

.nav-btn.disabled {
  opacity: 0.5;
}

/* 加载中 */
.loading-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #d4c4b0;
  border-top-color: #a53232;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 32rpx;
  color: #8a2525;
  margin-bottom: 15rpx;
}

.loading-sub {
  font-size: 24rpx;
  color: #8b7355;
}

/* 结果页 */
.result-screen {
  padding: 20rpx 0;
}

.result-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.result-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #8a2525;
  margin-bottom: 20rpx;
}

.constitution-badge {
  display: inline-block;
  background: linear-gradient(135deg, #a53232 0%, #8a2525 100%);
  color: white;
  padding: 15rpx 40rpx;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
}

/* 结果卡片 */
.result-card {
  background: #fffdf8;
  border-radius: 4rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(43, 27, 18, 0.12);
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #a53232;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #f0e8d8;
}

.card-content {
  font-size: 28rpx;
  color: #5d4037;
  line-height: 1.8;
}

/* 溯源 */
.sources-section {
  margin: 30rpx 0;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #8a2525;
  margin-bottom: 20rpx;
}

.source-item {
  background: #fffdf8;
  border-radius: 4rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #a53232;
}

.source-book {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #a53232;
  margin-bottom: 10rpx;
}

.source-text {
  display: block;
  font-size: 26rpx;
  color: #5d4037;
  line-height: 1.6;
  margin-bottom: 10rpx;
}

.source-original {
  display: block;
  font-size: 24rpx;
  color: #8b7355;
  font-style: italic;
  background: #f7f3e9;
  padding: 15rpx;
  border-radius: 2rpx;
}

/* 推荐 */
.recommend-section {
  margin: 30rpx 0;
}

.recommend-subtitle {
  display: block;
  font-size: 26rpx;
  color: #8b7355;
  margin-bottom: 20rpx;
}

.recommend-list {
  display: flex;
  gap: 20rpx;
  overflow-x: auto;
}

.recommend-card {
  min-width: 200rpx;
  background: #fffdf8;
  border-radius: 4rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(43, 27, 18, 0.12);
}

.recommend-img {
  width: 200rpx;
  height: 150rpx;
  background: #efe8d8;
}

.recommend-info {
  padding: 15rpx;
}

.recommend-name {
  display: block;
  font-size: 24rpx;
  color: #2b2b2b;
  margin-bottom: 8rpx;
}

.recommend-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #a53232;
}

/* 警告 */
.warning-box {
  display: flex;
  align-items: flex-start;
  background: #f7f3e9;
  border-radius: 4rpx;
  padding: 30rpx;
  margin: 30rpx 0;
}

.warning-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.warning-text {
  flex: 1;
  font-size: 26rpx;
  color: #8b7355;
  line-height: 1.6;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  padding: 30rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #a53232 0%, #8a2525 100%);
  color: white;
}

.action-btn.secondary {
  background: #efe8d8;
  color: #5a5a5a;
}
